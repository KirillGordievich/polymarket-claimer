LOG_LEVEL=info

# RPC used to interact with the Polygon network. You can use a public RPC or set up your own node for better performance and reliability.
RPC_URL=https://polygon-bor-rpc.publicnode.com

# Wallet
PROXY_WALLET=
# WARNING: Never commit your private key to version control. This is just an example and should be replaced with your actual private key in a secure manner.
PRIVATE_KEY=

# Builder API (https://polymarket.com/settings?tab=builder)
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Claim interval in seconds (default: 300 = 5 min)
CLAIM_INTERVAL_SEC=300

# Set to true to simulate the claiming process without actually sending transactions. Useful for testing.
DRY_RUN=false
